rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Users collection: User registration and status tracking
    match /Users/{userId} {
      allow read, write: if true;
    }
    
    // 2. Emotions collection: Students' daily emotions and drawing URLs
    match /Emotions/{emotionId} {
      allow read, write: if true;
    }
    
    // 3. teams collection & subcollections: Team progress and mission completions
    match /teams/{teamId} {
      allow read, write: if true;
      
      match /dailyMissions/{date} {
        allow read, write: if true;
      }
    }
  }
}
